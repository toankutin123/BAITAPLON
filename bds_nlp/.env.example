# Database
# For local development without PostgreSQL, use SQLite
DATABASE_URL=sqlite:///./bds_nlp.db

# For production with PostgreSQL, use:
# DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/bds_nlp

# Application
DEBUG=false
LOG_LEVEL=INFO

# Crawler
CRAWLER_HEADLESS=true
CRAWLER_TIMEOUT=60000
CRAWLER_RETRY_COUNT=3
CRAWLER_DELAY_SECONDS=2.0
CRAWLER_MAX_PAGES_PER_SOURCE=50

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_CRON_HOUR=0
SCHEDULER_CRON_MINUTE=0

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Sources
SOURCES=["https://batdongsan.com.vn/ban-nha-rieng-ha-noi","https://batdongsan.com.vn/ban-nha-rieng-tp-hcm","https://batdongsan.com.vn/ban-nha-rieng-da-nang"]
